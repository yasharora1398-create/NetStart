# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Next.js build artefacts
.next/
out/
next-env.d.ts

# Mobile Expo web bundle is generated into public/m by `npm run build`
# (npm --prefix mobile run web:export). Build artifact, not source.
/public/m/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Secrets - never commit
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
credentials.json
credentials.*
secrets.*
service-account*.json

# Claude local settings (per-user, not shared)
.claude/settings.local.json

# Stray nested clone of the repo, not part of the codebase.
/NetStart/

# Expo CLI cache that lands here if expo commands are run from
# the repo root. The mobile app lives in /mobile and ignores
# its own .expo separately.
.expo/
.expo-shared/
