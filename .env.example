VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional. AI matching (Gemini text-embedding-004, free tier).
# Get a key at https://aistudio.google.com -> Get API key.
# Without this, matching falls back to deterministic keyword scoring.
VITE_GEMINI_API_KEY=

# Optional. Set to 1 once you have deployed the Supabase Edge Function
# at supabase/functions/embed (see header comment for instructions).
# When enabled, embeddings are generated via the function so the API key
# never ships in the browser bundle. Leave unset for local dev with the
# direct VITE_GEMINI_API_KEY path above.
VITE_USE_EMBED_FUNCTION=
